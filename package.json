{
  "name": "mini-sortable",
  "version": "1.0.0",
  "description": "Tiny drag-to-reorder library for lists, grids, and cross-container transfer",
  "type": "module",
  "main": "sortable.js",
  "exports": {
    ".": "./sortable.js",
    "./alpine": "./alpine-sortable.js",
    "./hooks": "./hooks-sortable.js"
  },
  "files": [
    "sortable.js",
    "alpine-sortable.js",
    "hooks-sortable.js",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "check": "npx tsc --noEmit",
    "test": "npx playwright test",
    "prepublishOnly": "npm run check"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maxjustus/mini-sortable.git"
  },
  "keywords": [
    "sortable",
    "drag-and-drop",
    "reorder",
    "flip",
    "vanilla-js"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/maxjustus/mini-sortable/issues"
  },
  "homepage": "https://github.com/maxjustus/mini-sortable#readme",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-jsdoc": "^1.8.0",
    "typescript": "^5.9.3"
  }
}
