{
  "name": "mini-sortable",
  "version": "1.0.0",
  "description": "Tiny drag-to-reorder library for lists, grids, and cross-container transfer",
  "type": "module",
  "main": "dist/sortable.js",
  "module": "dist/sortable.mjs",
  "types": "dist/sortable.d.ts",
  "exports": {
    ".": {
      "types": "./dist/sortable.d.ts",
      "import": "./dist/sortable.mjs",
      "default": "./dist/sortable.js"
    },
    "./alpine": {
      "types": "./dist/alpine-sortable.d.ts",
      "import": "./dist/alpine-sortable.mjs",
      "default": "./dist/alpine-sortable.js"
    },
    "./hooks": {
      "types": "./dist/hooks-sortable.d.ts",
      "import": "./dist/hooks-sortable.mjs",
      "default": "./dist/hooks-sortable.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "node build.js",
    "check": "npx tsc --noEmit",
    "test": "npx playwright test",
    "prepublishOnly": "npm run build && npm run check"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maxjustus/mini-sortable.git"
  },
  "keywords": [
    "sortable",
    "drag-and-drop",
    "reorder",
    "flip",
    "vanilla-js"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/maxjustus/mini-sortable/issues"
  },
  "homepage": "https://github.com/maxjustus/mini-sortable#readme",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "esbuild": "^0.27.4",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
