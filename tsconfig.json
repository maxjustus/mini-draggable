{
  "compilerOptions": {
    "strict": true,
    "checkJs": true,
    "allowJs": true,
    "noEmit": true,
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true
  },
  "include": ["sortable.js", "alpine-sortable.js", "hooks-sortable.js"],
  "exclude": ["playwright.config.js"]
}
